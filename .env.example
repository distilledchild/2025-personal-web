# Frontend API URL (development: localhost:4100, production: Cloud Run)
VITE_API_URL=http://localhost:4100
PORT=4100

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback
VITE_GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback

# MongoDB
MONGODB_URI=your-mongodb-uri

# Google Cloud Platform
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-gcs-bucket-name
BILLING_BQ_EXPORT_TABLE=your-project.billing_export.gcp_billing_export_resource_v1_xxxx
BILLING_BQ_EXPORT_DATASET=billing_export
BILLING_BQ_LOCATION=US
BILLING_SERVICE_DESCRIPTION=Generative Language API
BILLING_API_KEY_LABEL=api_key
BILLING_ACCOUNT_EMAIL=wellclouder@gmail.com

# Strava OAuth
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
STRAVA_REDIRECT_URI=http://localhost:3000/strava/callback

# Blog publish -> n8n webhook (optional)
N8N_BLOG_PUBLISH_WEBHOOK_URL=https://n8n.distilledchild.space/webhook/blog-publish-obsidian-sync
N8N_BLOG_PUBLISH_WEBHOOK_TOKEN=your-webhook-token

# FRED macroeconomic indicators (required for finance macro and FOMC data)
FRED_API_KEY=your-fred-api-key

# Alpha Vantage News Sentiment (optional, used by finance macro indicators)
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key

# PaperFinder API enrichment
NCBI_EMAIL=your-email@example.com
NCBI_API_KEY=your-ncbi-api-key
SEMANTIC_SCHOLAR_API_KEY=your-semantic-scholar-api-key
ZOTERO_API_KEY=your-zotero-api-key
ZOTERO_USER_ID=your-zotero-user-id
ZOTERO_LIBRARY_ID=your-zotero-library-id
ZOTERO_LIBRARY_TYPE=user

# OpenClaw security audit reporter (optional)
# Set token to enable POST /api/security-audit/report
OPENCLAW_AUDIT_REPORT_TOKEN=your-long-random-token
# Optional: allow BLOG_API_KEY as fallback token for audit report endpoint
# Keep false unless you intentionally want shared key auth.
OPENCLAW_AUDIT_ALLOW_BLOG_API_KEY=false
# Set to false if you only want remote laptop reports (disable server-local scheduler)
ENABLE_OPENCLAW_AUDIT=true

# Academic CV Sync (Google Docs -> PDF on GCS)
# To secure the Google Doc URL, set CV_SOURCE_DOC_ID directly instead of using a local .gdoc path.
CV_SOURCE_DOC_ID=your-source-google-doc-id
CV_TARGET_DRIVE_FILE_ID=your-target-pdf-drive-file-id
CV_SYNC_TOKEN=your-cv-sync-token
ENABLE_ACADEMIC_CV_WATCH=true
CV_SYNC_QUIET_WINDOW_SECONDS=300
GCS_BUCKET_NAME=distilledchild
CV_GCS_OBJECT=about/cv.pdf
